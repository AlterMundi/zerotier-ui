mixin nav_item(name, displayName, href)
  li(class=((navigate && navigate.active === name) ? 'active' : ''))
    a(href=href) #{displayName}

mixin json_value(value)
  span.zt-jv(data-zt-json=JSON.stringify(value))

doctype html
html(lang='en')
  head
    title= title
    meta(charset='utf-8')
    meta(name='viewport', content='width=device-width, initial-scale=1')
    link(rel='stylesheet', href='/bscss/bootstrap.min.css')
    link(rel='stylesheet', href='/stylesheets/style.css')
    script(src='/jqjs/jquery.min.js')
    script(src='/bsjs/bootstrap.min.js')
    style.
      /* === ZT JSON Tree Viewer === */
      .zt-jv {
        font-family: 'SFMono-Regular', 'Fira Code', Consolas, 'Liberation Mono', monospace;
        font-size: 0.82em;
        line-height: 1.7;
        vertical-align: top;
      }
      /* Primitive types */
      .zt-s  { color: #032f62; }
      .zt-n  { color: #005cc5; font-weight: 500; }
      .zt-b  { color: #d73a49; font-weight: 600; }
      .zt-nl { color: #6a737d; font-style: italic; }
      /* Keys and structure */
      .zt-k  { color: #24292e; font-weight: 500; }
      .zt-br { color: #6a737d; }
      /* Tree nodes */
      .zt-nd { display: inline; }
      .zt-nd.zt-open   > .zt-ch    { display: block; }
      .zt-nd.zt-closed > .zt-ch    { display: none; }
      .zt-nd.zt-open   > .zt-ch-sum { display: none; }
      .zt-nd.zt-closed > .zt-ch-sum { display: inline; }
      /* Children container with indent guide */
      .zt-ch {
        display: block;
        padding-left: 14px;
        border-left: 2px solid #e1e4e8;
        margin: 2px 0 2px 4px;
      }
      .zt-item { display: block; padding: 1px 0; }
      /* Collapsed summary */
      .zt-ch-sum { color: #6a737d; font-style: italic; margin-left: 1px; }
      /* Toggle button */
      .zt-tog {
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 14px; height: 14px;
        border-radius: 3px;
        background: #f1f3f5;
        border: 1px solid #d1d5da;
        color: #586069;
        font-size: 7px;
        line-height: 1;
        user-select: none;
        vertical-align: middle;
        margin-right: 2px;
        transition: background 0.12s, color 0.12s;
      }
      .zt-tog:hover { background: #e1e4e8; color: #24292e; }
  body
    nav.navbar.navbar-inverse.navbar-fixed-top
      .container-fluid
        .navbar-header
          button.navbar-toggle(type='button' data-toggle='collapse' data-target='#BarNav')
            span.icon-bar
            span.icon-bar
            span.icon-bar
          a.navbar-brand(href='https://key-networks.com' target='_blank')
            img(src='/images/key-logo.svg' alt='Key Networks logo' height='25px' width='25px' style='display: inline')
            |  Key Networks
        .collapse.navbar-collapse(id='BarNav')
          ul.nav.navbar-nav
            block nav_items
          ul.nav.navbar-nav.navbar-right
            li
              block nav_login
                a(href='/logout')
                  span.glyphicon.glyphicon-log-out
                  |  Logout
    block body_content
    script.
      (function () {
        var esc = function (s) {
          return String(s)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
        };

        function renderVal(v, depth) {
          if (v === null) return '<span class="zt-nl">null</span>';
          var t = typeof v;
          if (t === 'boolean') return '<span class="zt-b">' + v + '</span>';
          if (t === 'number')  return '<span class="zt-n">' + v + '</span>';
          if (t === 'string')  return '<span class="zt-s">&quot;' + esc(v) + '&quot;</span>';

          var isArr = Array.isArray(v);
          var keys  = isArr ? null : Object.keys(v);
          var len   = isArr ? v.length : keys.length;
          var br    = isArr ? ['[', ']'] : ['{', '}'];

          if (len === 0) return '<span class="zt-br">' + br[0] + br[1] + '</span>';

          /* auto-expand root and first level; collapse deeper */
          var cls = (depth < 2) ? 'zt-open' : 'zt-closed';
          var icon = (cls === 'zt-open') ? '&#9660;' : '&#9654;';

          var previewKeys = isArr ? [] : keys.slice(0, 3);
          var sum = isArr
            ? len + (len === 1 ? ' item' : ' items')
            : previewKeys.map(esc).join(', ') + (len > 3 ? ', \u2026' : '');

          var o = '<span class="zt-nd ' + cls + '">';
          o += '<span class="zt-tog">' + icon + '</span>';
          o += '<span class="zt-br">' + br[0] + '</span>';
          o += '<span class="zt-ch-sum">&nbsp;<span class="zt-nl">' + esc(sum) + '</span></span>';
          o += '<span class="zt-ch">';

          var items = isArr ? v : keys;
          items.forEach(function (item, i) {
            var val = isArr ? item : v[item];
            o += '<span class="zt-item">';
            if (!isArr) {
              o += '<span class="zt-k">' + esc(item) + '</span>';
              o += '<span class="zt-br">: </span>';
            }
            o += renderVal(val, depth + 1);
            if (i < len - 1) o += '<span class="zt-br">,</span>';
            o += '</span>';
          });

          o += '</span>';
          o += '<span class="zt-br">' + br[1] + '</span>';
          o += '</span>';
          return o;
        }

        $(function () {
          $('[data-zt-json]').each(function () {
            try {
              var val = JSON.parse($(this).attr('data-zt-json'));
              $(this).html(renderVal(val, 0));
            } catch (err) {
              $(this).text($(this).attr('data-zt-json'));
            }
          });

          $(document).on('click', '.zt-tog', function (e) {
            e.stopPropagation();
            var $nd   = $(this).closest('.zt-nd');
            var isOpen = $nd.hasClass('zt-open');
            $nd.toggleClass('zt-open', !isOpen).toggleClass('zt-closed', isOpen);
            $(this).html(isOpen ? '&#9654;' : '&#9660;');
          });
        });
      })();
