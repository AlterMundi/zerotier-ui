extends network_layout

block net_content
  script.
    $(function() {
      $('.checkbox').on('click', function() {
        $.post('', {'ssoEnabled': $('#ssoEnabledCheckBox').is(':checked')});
      });
    });

  form(method='POST' action='')
    table.table.table-responsive.table-striped.table-hover
      tr
        td(width='3%')
          input#ssoEnabledCheckBox.checkbox(type='checkbox' checked=(network.ssoEnabled ? true : false))
        td Enable SSO authentication for this network (requires authorizationEndpoint and clientId).

  if errors
    ul
      for err in errors
        li!= err.msg
